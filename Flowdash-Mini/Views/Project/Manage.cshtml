@using Flowdash_Mini.Enums
@using Flowdash_Mini.ViewModels.Members
@using Flowdash_Mini.ViewModels.Projects
@using Microsoft.Extensions.Options
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Manage Project";

    List<ProjectMemberVM> members = ViewBag.Members;
    string date = Model.DateRange;
}
@inject IOptions<CaptchaOptions> captcha
@model EditProjectVM

<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="mb-0">Manage Project - @Model.ProjectName</h5>
        <small class="text-muted float-end">@DateTime.Now.ToString("dd MMM, yyyy")</small>
    </div>
    <div class="card-body">
        <form class="extra-validate" novalidate autocomplete="off" id="reCaptcha-form"
              method="POST" asp-controller="Project" asp-action="Manage">

            <input asp-for="CreatedAt" hidden />
            <input asp-for="Id" hidden />
            <input name="g-recaptcha-response" hidden />

            @Html.AntiForgeryToken()

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="basic-default-code">Project Code</label>
                <div class="col-sm-10">
                    <div class="position-relative">
                        <input type="text" class="form-control" id="basic-default-code"
                               asp-for="ProjectCode" readonly>
                        <button onclick="copy('@Model.ProjectCode')" class="text-white btn p-2 btn-secondary d-flex justify-content-center align-items-center position-absolute cstm-copybn" type="button">
                            <i class="bx bx-copy"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="basic-default-name">Project Name</label>
                <div class="col-sm-10">
                    <input type="text" class="form-control" id="basic-default-name"
                           asp-for="ProjectName" maxlength="100" placeholder="Enter Project name..." required>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="basic-default-description">Short Description</label>
                <div class="col-sm-10">
                    <textarea class="form-control" asp-for="Description" id="basic-default-description" maxlength="200"
                              placeholder="Enter Project Description..." required></textarea>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="basic-default-state">Company</label>
                <div class="col-sm-10">
                    <select class="form-select" asp-for="State" id="basic-default-state" required>
                        <option value="@ProjectState.Public">Public (Open for everyone)</option>
                        <option value="@ProjectState.Private">Private (Join using link only)</option>
                        <option value="@ProjectState.Personal">Personal (Nobody can join)</option>
                    </select>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="basic-default-tags">Tags</label>
                <div class="col-sm-10">
                    <input maxlength="200" asp-for="Tags" class="form-control"
                           id="basic-default-tags"
                           type="text"
                           placeholder="Enter Tags...">
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="basic-default-daterange">Start Date - End Date</label>
                <div class="col-sm-10">
                    <input type="text" asp-for="DateRange" class="daterange-picker form-control"
                           placeholder="Date range..." id="basic-default-daterange" />
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="basic-default-members">
                    Max Allowed Members
                </label>

                <div class="col-sm-10 d-flex align-items-center gap-3">
                    <h5 class="m-0">
                        <span id="a1-3db">1</span>
                    </h5>
                    <input class="form-range" asp-for="MaxMembersLimit"
                           id="basic-default-members"
                           type="range" min="@members.Count" max="99"
                           oninput="$('#a1-3db').text(this.value)">
                    <h5 class="m-0">99</h5>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <ul class="mb-0">
                            <li>@error.ErrorMessage</li>
                        </ul>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            }

            <div class="row justify-content-end">
                <div class="col-sm-10">
                    <button type="submit" class="btn btn-primary">Save & Apply Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://www.google.com/recaptcha/api.js?hl=en&render=@captcha.Value.SiteKey" async defer></script>
    <script src="~/lib/choices/choices.min.js"></script>
    <script>
        $(function () {
            // Begin Script
            $('#a1-3db').text('@Model.MaxMembersLimit')
            $('#manage-mbtn').addClass('active')

            let captchaDone = false;
            $("#reCaptcha-form").on('submit', function (e) {
                if (captchaDone) return;

                e.preventDefault();

                const form = this;
                if (!form.checkValidity()) {
                    form.classList.add('was-validated');
                    return;
                }

                grecaptcha.ready(function () {
                    grecaptcha.execute('@captcha.Value.SiteKey', { action: 'RESET_PASSWORD' })
                        .then(function (token) {
                            form.querySelector('input[name="g-recaptcha-response"]').value = token;
                            captchaDone = true;
                            form.submit();
                        });
                });
            });

            var textRemove = new Choices(document.getElementById('basic-default-tags'), {
              delimiter: ',',
              editItems: true,
              placeholderValue: 'Enter Tags (max 5)',
              maxItemCount: 5,
              removeItemButton: true
            });

            document.querySelectorAll('.choices__input').forEach(input => {
                input.addEventListener('input', function () {
                    const start = this.selectionStart;
                    const end = this.selectionEnd;

                    const oldValue = this.value;
                    const newValue = oldValue.replace(/[^a-zA-Z0-9_]/g, '');

                    if (oldValue !== newValue) {
                        this.value = newValue;

                        const diff = oldValue.length - newValue.length;
                        this.setSelectionRange(start - diff, end - diff);
                    }
                });
            });
            // End Script
        });
    </script>
}