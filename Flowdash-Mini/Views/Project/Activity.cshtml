@using Flowdash_Mini.Enums
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Activity";
    int x = 1;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="fw-bold py-3 mb-4"><a href="/project" class="text-muted fw-light">Project /</a> Activity Log</h4>
        <div class="d-flex gap-3 align-items-center justify-content-center">
            <a href="javascript:void(0);" class="refresh-btn btn btn-outline-secondary d-flex justify-content-center align-items-center gap-2">
                <i class="bx bx-refresh-cw"></i> <span>Refresh</span>
            </a>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <h5 class="card-header">Activity Log</h5>
                <div class="card-body">
                    <div class="table-responsive table-responsive text-nowrap">
                        <table class="table table-bordered data-table-list">
                            <thead>
                                <tr>
                                    <th>
                                        #
                                    </th>
                                    <th>
                                        <h6 class="m-0">Action</h6>
                                    </th>
                                    <th>
                                        <h6 class="m-0">Date & Time</h6>
                                    </th>
                                    <th>
                                        <h6 class="m-0">Member</h6>
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="list">
                                <tr>
                                    <td class="text-start">
                                        <h6 class="m-0">@(x++)</h6>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center justify-content-start">
                                            <h6 class="m-0">
                                                Completed Task 34EcxYkLD
                                            </h6>
                                        </div>
                                    </td>
                                    <td>
                                        <h6 class="m-0">28 Sep, 2025 11:53 AM</h6>
                                    </td>
                                    <td>
                                        <h6 class="d-flex justify-content-center align-items-center gap-2 m-0">
                                            <span>Humam</span>
                                            <span class="badge bg-label-warning text-warning">Owner</span>
                                        </h6>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <h6 class="m-0">@(x++)</h6>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center justify-content-start">
                                            <h6 class="m-0">
                                                Created a new Task 'Do a Research'
                                            </h6>
                                        </div>
                                    </td>
                                    <td>
                                        <h6 class="m-0">26 Sep, 2025 06:53 PM</h6>
                                    </td>
                                    <td>
                                        <h6 class="d-flex justify-content-center align-items-center gap-2 m-0">
                                            <span>Ahmed</span>
                                            <span class="badge bg-label-primary text-primary">User</span>
                                        </h6>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <h6 class="m-0">@(x++)</h6>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center justify-content-start">
                                            <h6 class="m-0">
                                                Ali joined the project using a link
                                            </h6>
                                        </div>
                                    </td>
                                    <td>
                                        <h6 class="m-0">23 Sep, 2025 09:22 AM</h6>
                                    </td>
                                    <td>
                                        <h6 class="d-flex justify-content-center align-items-center gap-2 m-0">
                                            <span>Ali</span>
                                            <span class="badge bg-label-primary text-primary">User</span>
                                        </h6>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <h6 class="m-0">@(x++)</h6>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center justify-content-start">
                                            <h6 class="m-0">
                                                Posted a new announcement
                                            </h6>
                                        </div>
                                    </td>
                                    <td>
                                        <h6 class="m-0">20 Sep, 2025 10:09 AM</h6>
                                    </td>
                                    <td>
                                        <h6 class="d-flex justify-content-center align-items-center gap-2 m-0">
                                            <span>Saad</span>
                                            <span class="badge bg-label-success text-success">Admin</span>
                                        </h6>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <h6 class="m-0">@(x++)</h6>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center justify-content-start">
                                            <h6 class="m-0">
                                                Osama was invited to join the project by Humam
                                            </h6>
                                        </div>
                                    </td>
                                    <td>
                                        <h6 class="m-0">15 Sep, 2025 09:25 PM</h6>
                                    </td>
                                    <td>
                                        <h6 class="d-flex justify-content-center align-items-center gap-2 m-0">
                                            <span>Humam</span>
                                            <span class="badge bg-label-warning text-warning">Owner</span>
                                        </h6>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(function () {
            $('#activity-mbtn').addClass('active')
        })
    </script>
}