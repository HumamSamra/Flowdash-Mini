@using Flowdash_Mini.Enums
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Progress";
}

<div class="flex-grow-1">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="fw-bold py-3 mb-4"><a href="/project" class="text-muted fw-light">Project /</a> Progress</h4>
        <div class="d-flex gap-3 align-items-center justify-content-center">
            @if (ViewBag.MemberType != MemberType.User)
            {
                <a href="javascript:void(0);" class="btn btn-primary d-flex justify-content-center align-items-center gap-2">
                    <i class="bx bx-plus"></i> <span>Create Task Board</span>
                </a>
            }
            <a href="javascript:void(0);" class="refresh-btn btn btn-outline-secondary d-flex justify-content-center align-items-center gap-2">
                <i class="bx bx-refresh-cw"></i> <span>Refresh</span>
            </a>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 order-1">
            <div class="row">
                <div class="col-md-6 col-lg-4 col-xl-4 order-0 mb-4">
                    <div class="card h-100">
                        <div class="card-header mb-3 d-flex align-items-center justify-content-between pb-0">
                            <div class="card-title mb-0">
                                <h5 class="m-0 me-2">Untitled Task Board</h5>
                                <small class="text-muted">Completed 21 out of 32 Tasks</small>
                            </div>
                            <div class="dropdown">
                                <button type="button" class="btn p-0 dropdown-toggle hide-arrow"
                                        data-bs-toggle="dropdown" aria-expanded="true">
                                    <i class="bx bx-dots-vertical-rounded"></i>
                                </button>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="javascript:void(0))">
                                        <i class="bx bx-edit-alt me-1"></i>
                                        <span>Edit</span>
                                    </a>
                                    <a class="dropdown-item" href="javascript:void(0))">
                                        <i class="bx bx-trash me-1"></i>
                                        <span>Delete</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <h6 class="mb-2">Task Board Progress:</h6>
                            <div class="progress mb-3">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 20%" aria-valuenow="20" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <div class="d-flex justify-content-end">
                                <a class="btn btn-primary btn-sm" href="/project/taskboard">
                                    Open Task Board
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#progress-mbtn').addClass('active')
        })
    </script>
}